NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

MONGODB_URI=mongodb://localhost:27017/ell-pageant

JWT_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated list of allowed client origins (public app, admin panel, etc.)
CORS_ORIGINS=http://localhost:3000

THROTTLE_TTL=60000
THROTTLE_LIMIT=100

STORAGE_DRIVER=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

PAYSTACK_SECRET_KEY=
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
PRICE_PER_VOTE_PAISE=100

SEED_ADMIN_EMAIL=admin@ellpageant.com
SEED_ADMIN_PASSWORD=Admin123!@#
SEED_ADMIN_NAME=System Admin
